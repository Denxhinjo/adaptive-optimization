# Copy to .env and adjust as needed. No secrets are required to run the
# dashboard locally or in Docker; this file exists so deployment platforms
# (Streamlit Community Cloud, Docker, etc.) have a documented config surface.

# Directory where downloaded datasets (a9a, MNIST) are cached.
ADAPTIVE_OPT_DATA_DIR=datasets/raw

# Directory where experiment outputs (CSVs, figures, animations) are written.
ADAPTIVE_OPT_RESULTS_DIR=results

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
ADAPTIVE_OPT_LOG_LEVEL=INFO
